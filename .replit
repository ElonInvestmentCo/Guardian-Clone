modules = ["nodejs-20", "nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["resend:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
ADMIN_JWT_SECRET = "39a3ecb228c63217460bc6e425ad21ffc8073905791eeaf85e0f79162839c83df32ee48c0035ed1871301a25eacc6ebe"
ADMIN_USERNAME = "no-reply"
ADMIN_PASSWORD_HASH = "$2b$12$F/jZHDFnNbar4ADuzCmw8.IXeS1I6b9zGNMVrtPYXMQ1InqU9BIQy"
