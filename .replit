modules = ["nodejs-20", "web", "bash", "postgresql-16"]

  [deployment]
  router = "application"
deploymentTarget = "vm"
build = ["bash", "scripts/build-production.sh"]
run = ["node", "artifacts/api-server/dist/index.cjs"]

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Guardian Trading"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin KYC"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 NODE_ENV=development tsx server/index.ts"
waitForPort = 3001

[[workflows.workflow]]
name = "Guardian Trading"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 API_PORT=3001 vite"
waitForPort = 5000

[[workflows.workflow]]
name = "Admin KYC"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 API_PORT=3001 vite --config vite.admin.config.ts"
waitForPort = 8080

  [agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["resend:1.0.0", "javascript_openai_ai_integrations:2.0.0"]

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000

  [nix]
channel = "stable-25_05"
packages = ["nano", "railway"]

  [userenv]

[userenv.development]

[userenv.shared]
NODE_ENV = "development"
API_PORT = "3001"
ADMIN_EMAIL = "support@guardiiantrading.com"
SIGNATURE_THRESHOLD = "10"
ADMIN_USERNAME = "guardian_admin"
ALLOWED_ORIGINS = "https://guardian-trading.com,https://guardian-trading-api-production.up.railway.app,http://localhost:3000"
CLOUDFLARE_ACCOUNT_ID = "362471d6543a4e5c8be69471f21f7129"
CLOUDFLARE_EMAIL = "lucyaiswap@gmail.com"
CLOUDFLARE_ZONE_ID = "1817090b066f9596c81edea585dbf9b9"
TURNSTILE_SITE_KEY = "0x4AAAAAADYKOYkOE03vrvkE"
VITE_TURNSTILE_SITE_KEY = "0x4AAAAAADYKOYkOE03vrvkE"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 5173

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 8083
externalPort = 4200
