modules = ["nodejs-20", "web", "bash"]

  [[artifacts]]
  id = "artifacts/api-server"

  [[artifacts]]
  id = "artifacts/mockup-sandbox"

  [deployment]
  router = "application"
  deploymentTarget = "autoscale"
  build = ["bash", "scripts/build-production.sh"]
  run = ["node", "artifacts/api-server/dist/index.cjs"]

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin KYC"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ API_PORT=3001 pnpm --filter @workspace/guardian-trading run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 pnpm --filter @workspace/api-server run dev"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Admin KYC"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 BASE_PATH=/admin-kyc/ API_PORT=3001 pnpm --filter @workspace/admin-kyc run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

  [agent]
  stack = "PNPM_WORKSPACE"
expertMode = true
  integrations = ["resend:1.0.0"]

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000

  [nix]
channel = "stable-25_05"

  [userenv]

  [userenv.shared]
USER_DATA_KEY = "a4ad8bf066b8560745779d7c544b986a112e1405a904b4a614a62a918e92a820"
  