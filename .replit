modules = ["nodejs-20", "web", "bash"]

  [[artifacts]]
  id = "artifacts/api-server"

  [[artifacts]]
  id = "artifacts/mockup-sandbox"

  [deployment]
  router = "application"
  deploymentTarget = "vm"
  build = ["bash", "scripts/build-production.sh"]
  run = ["node", "artifacts/api-server/dist/index.cjs"]

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Guardian Trading"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin KYC"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 pnpm run dev:server"
waitForPort = 3001

[[workflows.workflow]]
name = "Guardian Trading"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3000 BASE_PATH=/ API_PORT=3001 pnpm --filter @workspace/guardian-trading run dev"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Admin KYC"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 BASE_PATH=/admin-kyc/ API_PORT=3001 pnpm --filter @workspace/admin-kyc run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "webview"

  [agent]
  stack = "PNPM_WORKSPACE"
expertMode = true
  integrations = ["resend:1.0.0"]

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000

  [nix]
channel = "stable-25_05"

  [userenv]

  [userenv.shared]
